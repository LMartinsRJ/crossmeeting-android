<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclui SharedPreferences do backup na nuvem (contém tokens de sessão Supabase) -->
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclui SharedPreferences da transferência entre dispositivos -->
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
